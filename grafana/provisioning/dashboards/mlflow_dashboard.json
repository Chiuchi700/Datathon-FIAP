                      "queryText": "SELECT\n  r.run_uuid,\n  datetime(r.start_time / 1000, 'unixepoch') AS run_time,\n  MAX(CASE WHEN lm.key = 'rmse' THEN lm.value END) AS rmse,\n  MAX(CASE WHEN lm.key = 'mae' THEN lm.value END) AS mae,\n  MAX(CASE WHEN lm.key = 'mape' THEN lm.value END) AS mape,\n  MAX(CASE WHEN lm.key = 'direction_accuracy' THEN lm.value END) AS direction_accuracy,\n  MAX(CASE WHEN p.key = 'seq_length' THEN p.value END) AS seq_length,\n  MAX(CASE WHEN p.key = 'learning_rate' THEN p.value END) AS learning_rate,\n  MAX(CASE WHEN p.key = 'batch_size' THEN p.value END) AS batch_size\nFROM runs r\nLEFT JOIN latest_metrics lm\n  ON lm.run_uuid = r.run_uuid\nLEFT JOIN params p\n  ON p.run_uuid = r.run_uuid\nWHERE r.lifecycle_stage = 'active'\nGROUP BY r.run_uuid, r.start_time\nORDER BY rmse ASC\nLIMIT 20;",
                      "queryType": "table",
